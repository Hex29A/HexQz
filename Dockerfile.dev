# Dev Dockerfile with separate targets for server and client
FROM node:20-alpine AS server
WORKDIR /app/server
COPY server/package.json ./
RUN npm install
COPY server/ ./
RUN mkdir -p /app/data /app/uploads
WORKDIR /app

FROM node:20-alpine AS client
WORKDIR /app/client
COPY client/package.json ./
RUN npm install
COPY client/ ./
